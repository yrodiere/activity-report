#!/usr/bin/env bash
# Wrapper script for activity-report

set -e

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$SCRIPT_DIR/.."
QUARKUS_APP="$PROJECT_DIR/target/quarkus-app"

# Build if necessary (first run or if source is newer than jar)
if [ ! -d "$QUARKUS_APP" ] || [ "$PROJECT_DIR/pom.xml" -nt "$QUARKUS_APP/quarkus-run.jar" ] || \
   find "$PROJECT_DIR/src" -newer "$QUARKUS_APP/quarkus-run.jar" 2>/dev/null | grep -q .; then
    echo "Building activity-report..." >&2
    (cd "$PROJECT_DIR" && mvn -q clean package -DskipTests)
    echo "Build complete." >&2
    echo "" >&2
fi

JVM_ARGS=""
APP_ARGS=()
while [[ $# -gt 0 ]]; do
    case $1 in
        --trace)
            JVM_ARGS+=" -Dquarkus.log.console.level=TRACE"
            shift
            ;;
        -J)
            shift
            JVM_ARGS+=" $1"
            shift
            ;;
        *)
            APP_ARGS+=("$1")
            shift
            ;;
    esac
done

# Run the Quarkus application
exec java $JVM_ARGS -jar "$QUARKUS_APP/quarkus-run.jar" "${APP_ARGS[@]}"

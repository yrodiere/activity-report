# Activity Report Configuration
# Copy this file to ~/.config/activity-report/config.yaml
# See README.md for detailed setup instructions

providers:
  # GitHub (supports multiple instances: GitHub.com and GitHub Enterprise)
  github:
    enabled: true
    instances:
      # GitHub.com
      - name: "GitHub.com"
        url: "https://api.github.com"
        username: "your-github-username"
        # token: "op://Private/GitHub/token"
        # public-events-token: "op://Private/GitHub-Public-Events/token"
        # default-project: "Quarkus"

      # GitHub Enterprise (optional)
      # - name: "Company GitHub Enterprise"
      #   url: "https://github.company.com/api/v3"
      #   username: "your-ghe-username"
      #   token: "op://Work/GitHub-Enterprise/token?account=my-work-account"
      #   default-project: "Infrastructure"

  # JIRA (supports multiple instances)
  jira:
    enabled: false  # Set to true to enable
    instances:
      # - name: "Project JIRA"
      #   url: "https://yourcompany.atlassian.net"
      #   email: "your-email@example.com"
      #   token: "op://Private/JIRA/token"
      #   default-project: "Infrastructure"

  # Zulip (supports multiple instances)
  # Note: Zulip will automatically extract JIRA issue keys (e.g., PROJ-123) and resolve them
  # against configured JIRA instances for cross-provider grouping
  zulip:
    enabled: false  # Set to true to enable
    instances:
      # - url: "https://yourcompany.zulipchat.com"
      #   email: "your-email@example.com"
      #   api_key: "op://Private/Zulip/api_key"
      #   default-project: "Quarkus"

# AI Configuration (for intelligent report grouping)
ai:
  url: "http://localhost:8000/v1"  # Podman AI Lab default endpoint
  model: "auto"  # auto-detect from API, or specify model name

# Project classification (organizes report by projects based on URL patterns)
projects:
  - name: "Quarkus"
    url-patterns:
      - "https://github.com/quarkusio/*"
      - "https://github.com/quarkiverse/*"
  - name: "Hibernate ORM"
    url-patterns:
      - "https://github.com/hibernate/hibernate-orm/*"
      - "https://redhat.atlassian.net/browse/HHH-*"
  - name: "Hibernate Search"
    url-patterns:
      - "https://github.com/hibernate/hibernate-search/*"
      - "https://redhat.atlassian.net/browse/HSEARCH-*"
  - name: "Infrastructure"
    url-patterns:
      - "https://github.com/hibernate/hibernate.org/*"

# See README.md for detailed setup instructions, token creation, and credential management
